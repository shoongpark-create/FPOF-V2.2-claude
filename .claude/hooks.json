{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "command": ".claude/hooks/route-skill.sh \"$PROMPT\""
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "command": ".claude/hooks/check-output.sh \"$TOOL_INPUT\""
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "command": ".claude/hooks/team-task-completed.sh \"$TASK_DESCRIPTION\""
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "command": ".claude/hooks/team-idle.sh"
      }
    ]
  }
}
