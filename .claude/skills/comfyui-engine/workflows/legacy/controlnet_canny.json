{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load SDXL Checkpoint"},
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "2": {
    "class_type": "VAELoader",
    "_meta": {"title": "Load VAE"},
    "inputs": {
      "vae_name": "sdxl_vae_fp16_fix.safetensors"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Positive Prompt"},
    "inputs": {
      "text": "POSITIVE_PROMPT",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Negative Prompt"},
    "inputs": {
      "text": "NEGATIVE_PROMPT",
      "clip": ["1", 1]
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Empty Latent Image"},
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "10": {
    "class_type": "LoadImage",
    "_meta": {"title": "Load Reference Sketch"},
    "inputs": {
      "image": "input_sketch.png"
    }
  },
  "11": {
    "class_type": "ControlNetLoader",
    "_meta": {"title": "Load ControlNet Canny"},
    "inputs": {
      "control_net_name": "controlnet-canny-sdxl-1.0-fp16.safetensors"
    }
  },
  "12": {
    "class_type": "ControlNetApplyAdvanced",
    "_meta": {"title": "Apply ControlNet"},
    "inputs": {
      "positive": ["3", 0],
      "negative": ["4", 0],
      "control_net": ["11", 0],
      "image": ["10", 0],
      "strength": 0.8,
      "start_percent": 0.0,
      "end_percent": 1.0,
      "vae": ["2", 0]
    }
  },
  "6": {
    "class_type": "KSampler",
    "_meta": {"title": "KSampler"},
    "inputs": {
      "model": ["1", 0],
      "positive": ["12", 0],
      "negative": ["12", 1],
      "latent_image": ["5", 0],
      "seed": 0,
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "euler_ancestral",
      "scheduler": "normal",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"},
    "inputs": {
      "samples": ["6", 0],
      "vae": ["2", 0]
    }
  },
  "8": {
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"},
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "comfyui_controlnet"
    }
  }
}
