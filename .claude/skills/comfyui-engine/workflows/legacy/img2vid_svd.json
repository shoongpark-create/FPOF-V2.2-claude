{
  "1": {
    "class_type": "ImageOnlyCheckpointLoader",
    "_meta": {"title": "Load SVD Checkpoint"},
    "inputs": {
      "ckpt_name": "svd_xt.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "_meta": {"title": "Load Source Image"},
    "inputs": {
      "image": "source_image.png"
    }
  },
  "3": {
    "class_type": "SVD_img2vid_Conditioning",
    "_meta": {"title": "SVD Conditioning"},
    "inputs": {
      "clip_vision": ["1", 1],
      "init_image": ["2", 0],
      "vae": ["1", 2],
      "width": 1024,
      "height": 576,
      "video_frames": 25,
      "motion_bucket_id": 127,
      "fps": 6,
      "augmentation_level": 0.0
    }
  },
  "4": {
    "class_type": "KSampler",
    "_meta": {"title": "KSampler"},
    "inputs": {
      "model": ["1", 0],
      "positive": ["3", 0],
      "negative": ["3", 1],
      "latent_image": ["3", 2],
      "seed": 0,
      "steps": 20,
      "cfg": 2.5,
      "sampler_name": "euler",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "5": {
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"},
    "inputs": {
      "samples": ["4", 0],
      "vae": ["1", 2]
    }
  },
  "6": {
    "class_type": "SaveAnimatedWEBP",
    "_meta": {"title": "Save Video"},
    "inputs": {
      "images": ["5", 0],
      "filename_prefix": "comfyui_video",
      "fps": 6,
      "lossless": false,
      "quality": 85,
      "method": "default"
    }
  }
}
