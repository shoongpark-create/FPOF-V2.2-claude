{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load SDXL Checkpoint"},
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "2": {
    "class_type": "VAELoader",
    "_meta": {"title": "Load VAE"},
    "inputs": {
      "vae_name": "sdxl_vae_fp16_fix.safetensors"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Positive Prompt"},
    "inputs": {
      "text": "POSITIVE_PROMPT",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Negative Prompt"},
    "inputs": {
      "text": "NEGATIVE_PROMPT",
      "clip": ["1", 1]
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Empty Latent Image"},
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "20": {
    "class_type": "LoadImage",
    "_meta": {"title": "Load Style Reference"},
    "inputs": {
      "image": "reference_style.png"
    }
  },
  "21": {
    "class_type": "IPAdapterModelLoader",
    "_meta": {"title": "Load IP-Adapter"},
    "inputs": {
      "ipadapter_file": "ip-adapter-plus_sdxl_vit-h.safetensors"
    }
  },
  "22": {
    "class_type": "CLIPVisionLoader",
    "_meta": {"title": "Load CLIP Vision"},
    "inputs": {
      "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors"
    }
  },
  "23": {
    "class_type": "IPAdapterApply",
    "_meta": {"title": "Apply IP-Adapter"},
    "inputs": {
      "ipadapter": ["21", 0],
      "clip_vision": ["22", 0],
      "image": ["20", 0],
      "model": ["1", 0],
      "weight": 0.7,
      "noise": 0.3,
      "weight_type": "linear",
      "start_at": 0.0,
      "end_at": 1.0
    }
  },
  "6": {
    "class_type": "KSampler",
    "_meta": {"title": "KSampler"},
    "inputs": {
      "model": ["23", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0],
      "seed": 0,
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "euler_ancestral",
      "scheduler": "normal",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"},
    "inputs": {
      "samples": ["6", 0],
      "vae": ["2", 0]
    }
  },
  "8": {
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"},
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "comfyui_ipadapter"
    }
  }
}
