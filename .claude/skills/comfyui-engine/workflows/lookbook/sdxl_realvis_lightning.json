{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load RealVisXL V5.0 fp16"},
    "inputs": {
      "ckpt_name": "RealVisXL_V5.0_fp16.safetensors"
    }
  },
  "2": {
    "class_type": "VAELoader",
    "_meta": {"title": "Load VAE"},
    "inputs": {
      "vae_name": "sdxl_vae_fp16_fix.safetensors"
    }
  },
  "9": {
    "class_type": "LoraLoader",
    "_meta": {"title": "SDXL Lightning 4-step LoRA"},
    "inputs": {
      "model": ["1", 0],
      "clip": ["1", 1],
      "lora_name": "sdxl_lightning_4step_lora.safetensors",
      "strength_model": 1.0,
      "strength_clip": 1.0
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Positive Prompt"},
    "inputs": {
      "text": "POSITIVE_PROMPT",
      "clip": ["9", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Negative Prompt"},
    "inputs": {
      "text": "NEGATIVE_PROMPT",
      "clip": ["9", 1]
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Empty Latent Image"},
    "inputs": {
      "width": 832,
      "height": 1216,
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "KSampler",
    "_meta": {"title": "KSampler (Lightning 4-step)"},
    "inputs": {
      "model": ["9", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0],
      "seed": 0,
      "steps": 4,
      "cfg": 1.8,
      "sampler_name": "euler",
      "scheduler": "sgm_uniform",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"},
    "inputs": {
      "samples": ["6", 0],
      "vae": ["2", 0]
    }
  },
  "8": {
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"},
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "lookbook_realvis_lightning"
    }
  }
}
