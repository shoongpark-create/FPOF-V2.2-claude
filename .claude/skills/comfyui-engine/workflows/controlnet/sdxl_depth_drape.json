{
  "_comment": "SDXL ControlNet Depth — 의류 볼륨·드레이프·바디 착장감 제어. 의류가 신체 위에서 어떻게 쌓이는지 표현. MiDaS depth preprocessor. v2 (2026-04-10).",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load SDXL Checkpoint"},
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "2": {
    "class_type": "VAELoader",
    "_meta": {"title": "Load VAE"},
    "inputs": {
      "vae_name": "sdxl_vae_fp16_fix.safetensors"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Positive Prompt"},
    "inputs": {
      "text": "POSITIVE_PROMPT",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Negative Prompt"},
    "inputs": {
      "text": "NEGATIVE_PROMPT",
      "clip": ["1", 1]
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Empty Latent Image"},
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "10": {
    "class_type": "LoadImage",
    "_meta": {"title": "Load Reference Image"},
    "inputs": {
      "image": "input_reference.png"
    }
  },
  "11": {
    "class_type": "MiDaS-DepthMapPreprocessor",
    "_meta": {"title": "MiDaS Depth Preprocessor"},
    "inputs": {
      "image": ["10", 0],
      "a": 6.283185307179586,
      "bg_threshold": 0.1,
      "resolution": 1024
    }
  },
  "12": {
    "class_type": "ControlNetLoader",
    "_meta": {"title": "Load ControlNet Depth SDXL"},
    "inputs": {
      "control_net_name": "controlnet-depth-sdxl-1.0-fp16.safetensors"
    }
  },
  "13": {
    "class_type": "ControlNetApplyAdvanced",
    "_meta": {"title": "Apply Depth ControlNet"},
    "inputs": {
      "positive": ["3", 0],
      "negative": ["4", 0],
      "control_net": ["12", 0],
      "image": ["11", 0],
      "strength": 0.75,
      "start_percent": 0.0,
      "end_percent": 0.9,
      "vae": ["2", 0]
    }
  },
  "6": {
    "class_type": "KSampler",
    "_meta": {"title": "KSampler (depth drape)"},
    "inputs": {
      "model": ["1", 0],
      "positive": ["13", 0],
      "negative": ["13", 1],
      "latent_image": ["5", 0],
      "seed": 0,
      "steps": 30,
      "cfg": 6.5,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"},
    "inputs": {
      "samples": ["6", 0],
      "vae": ["2", 0]
    }
  },
  "8": {
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"},
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "cn_depth_drape"
    }
  }
}
