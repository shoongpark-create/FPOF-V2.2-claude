{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load SDXL Checkpoint"},
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "2": {
    "class_type": "VAELoader",
    "_meta": {"title": "Load VAE"},
    "inputs": {
      "vae_name": "sdxl_vae_fp16_fix.safetensors"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Positive Prompt"},
    "inputs": {
      "text": "POSITIVE_PROMPT",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Negative Prompt"},
    "inputs": {
      "text": "NEGATIVE_PROMPT",
      "clip": ["1", 1]
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Empty Latent Image"},
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "20": {
    "class_type": "LoadImage",
    "_meta": {"title": "Load Style Reference"},
    "inputs": {
      "image": "reference_style.png"
    }
  },
  "21": {
    "class_type": "IPAdapterUnifiedLoader",
    "_meta": {"title": "IPAdapter Unified Loader"},
    "inputs": {
      "model": ["1", 0],
      "preset": "PLUS (high strength)"
    }
  },
  "22": {
    "class_type": "IPAdapterAdvanced",
    "_meta": {"title": "IPAdapter Advanced"},
    "inputs": {
      "model": ["21", 0],
      "ipadapter": ["21", 1],
      "image": ["20", 0],
      "weight": 0.7,
      "weight_type": "ease in-out",
      "combine_embeds": "concat",
      "start_at": 0.0,
      "end_at": 1.0,
      "embeds_scaling": "V only"
    }
  },
  "6": {
    "class_type": "KSampler",
    "_meta": {"title": "KSampler (moodboard)"},
    "inputs": {
      "model": ["22", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0],
      "seed": 0,
      "steps": 30,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"},
    "inputs": {
      "samples": ["6", 0],
      "vae": ["2", 0]
    }
  },
  "8": {
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"},
    "inputs": {
      "images": ["7", 0],
      "filename_prefix": "moodboard_ipa_v2"
    }
  }
}
