        { "value": "womens_bottoms", "label": "우먼스 하의", "description": "미니스커트, 와이드팬츠, 숏팬츠" },
        { "value": "womens_dresses", "label": "우먼스 원피스/셋업", "description": "미니원피스, 셋업" },
        { "value": "accessories_bags", "label": "악세서리 가방", "description": "백팩, 크로스백, 토트백" },
