  "confirmation": {
    "summary_template": "수집된 브리프:\n- section_type: {section_type}\n- silhouette: {silhouette}\n- material: {material}\n- details: {details}\n- color: {color}\n- lighting: {lighting_quality}\n- shot: {shot}\n- channel: {channel}\n- style_lock: {style_lock}\n\n이대로 생성할까요?",
    "on_approve": {
      "save_brief_to": "workspace/{season}/{project}/brief_{timestamp}.json",
      "invoke": "python3.12 scripts/brief_compose.py --brief <saved_brief_path>"
    },
    "on_revise": "수정할 필드를 AskUserQuestion 으로 물어보고 해당 스텝만 다시 실행"
  }
