{
  "schema_version": "1.0",
  "purpose": "디자인 디스커버리 질문 트리 — 아이디어가 불투명한 사용자를 AskUserQuestion 연쇄로 구체화하여 Foundation Formula 7슬롯 브리프로 수렴시킨다. Claude가 이 파일을 읽고 steps 배열을 순서대로 AskUserQuestion 으로 렌더링한다. 각 스텝의 options 는 인라인 정의이거나, source 파일에서 동적 로드(keys/labels 규칙)로 구성된다.",
  "how_claude_uses_this": [
    "1. SKILL.md 모드 0 호출 시 이 파일을 로드한다.",
    "2. steps 를 순서대로 순회. 각 스텝마다:",
    "   a) skip_if 조건이 현재 brief 상태와 맞으면 건너뛴다.",
    "   b) options 필드가 인라인이면 그대로, source 필드가 있으면 해당 JSON 에서 동적 로드한다.",
    "   c) filter_by 가 있으면 brief 의 다른 필드 값으로 옵션을 필터링한다.",
    "   d) AskUserQuestion 호출 — question/header/multiSelect/options 를 인자로.",
    "   e) 사용자 답변을 brief[maps_to] 에 저장한다.",
    "3. 모든 스텝 완료 후 brief 를 JSON 요약해 보여주고 '이대로 생성할까요?' 확인.",
    "4. 승인되면 workspace 에 brief.json 저장 → scripts/brief_compose.py --brief <path> 실행."
  ],
  "brief_schema": {
    "description": "스텝이 채워넣는 brief.json 최종 형태. scripts/brief_compose.py 가 읽는 스키마.",
    "fields": {
      "section_type": "flat_sketch | lookbook | graphic | moodboard | colorway",
      "category": "선택 — MD 카테고리 (예: unisex_tops, womens_dresses, accessories_bags)",
      "silhouette": "foundation_formula.silhouette_templates 의 키 (예: oversized_hoodie)",
      "material": "material-intelligence.json 의 키 (예: french_terry_brushed)",
      "details": "foundation_formula.details_options 의 키 1개 (예: signature_stitching)",
      "color": "foundation_formula 자유 텍스트 또는 프리셋 (예: 'signature canary yellow dominant')",
      "construction": "foundation_formula.construction_options 의 키 (선택)",
      "shot": "foundation_formula.shot_type_options 의 키 (예: three_quarter)",
      "lighting_quality": "foundation_formula.lighting_quality_tags 의 키 (예: golden_hour)",
      "channel": "workflow-catalog.json.channel_to_ratio 의 키 (예: musinsa_hero)",
      "extra_raw": "자유 텍스트 — 위 슬롯으로 표현 안 되는 추가 디렉션",
      "ref_image": "moodboard 섹션 전용 — 참조 이미지 절대경로",
      "style_lock": "brand-prompt-kit.json.style_lock_presets 의 키 (선택)",
      "seed": "정수 (선택, 재현용)",
      "output": "출력 파일 경로"
    }
  },
  "steps": [
    {
