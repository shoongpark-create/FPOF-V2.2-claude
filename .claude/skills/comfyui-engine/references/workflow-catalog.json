{
  "schema_version": "2.0",
  "workflows": {
    "flat-sketch/sdxl_flat_linework.json": {
      "intent": "flat-sketch",
      "model_family": "sdxl",
      "requires_ref": false,
      "phase": 1,
      "description": "SDXL + low CFG + flat prompt. brand_booster OFF. Euler sampler."
    },
    "lookbook/sdxl_street_hires.json": {
      "intent": "lookbook",
      "model_family": "sdxl",
      "requires_ref": false,
      "phase": 1,
      "style_preset": "street",
      "description": "SDXL Base 거리 무드 착장 (balanced 속도, 기본 SDXL Base 1.0)"
    },
    "lookbook/sdxl_realvis_lightning.json": {
      "intent": "lookbook",
      "model_family": "sdxl",
      "requires_ref": false,
      "phase": 2,
      "speed": "fast",
      "style_preset": "street",
      "description": "RealVisXL V5.0 fp16 + SDXL Lightning 4-step LoRA (5-10초/장, 한국인 인물 품질 향상)",
      "overrides": {
        "sampler": "euler",
        "scheduler": "sgm_uniform",
        "steps": 4,
        "cfg": 1.8
      }
    },
    "moodboard/sdxl_ipadapter_v2.json": {
      "intent": "moodboard",
      "model_family": "sdxl",
      "requires_ref": true,
      "phase": 1,
      "api_version": 2,
      "description": "IPAdapterUnifiedLoader + IPAdapterAdvanced (구형 API 교체)"
    },
    "graphic/sdxl_print_vector.json": {
      "intent": "graphic",
      "model_family": "sdxl",
      "requires_ref": false,
      "phase": 1,
      "description": "SDXL 벡터 스타일 프린트 원고"
    },
    "colorway/sdxl_fixed_seed_swap.json": {
      "intent": "colorway",
      "model_family": "sdxl",
      "requires_ref": "optional-controlnet",
      "phase": 1,
      "requires_fixed_seed": true,
      "description": "동일 시드 + 프롬프트 컬러 토큰만 교체"
    },
    "controlnet/sdxl_canny_structure.json": {
      "intent": "structure_control",
      "sub_intent": "canny",
      "model_family": "sdxl",
      "requires_ref": true,
      "phase": 2,
      "description": "SDXL ControlNet Canny — 봉제선·실루엣·카라 구조 락. 레퍼런스 이미지의 엣지를 추출해 새 프롬프트로 재생성하되 형태는 유지. strength 0.85, end 0.85."
    },
    "controlnet/sdxl_depth_drape.json": {
      "intent": "structure_control",
      "sub_intent": "depth",
      "model_family": "sdxl",
      "requires_ref": true,
      "phase": 2,
      "description": "SDXL ControlNet Depth — 의류 볼륨·드레이프·바디 착장감 제어. MiDaS depth map. strength 0.75."
    },
    "controlnet/sdxl_softedge_material_swap.json": {
      "intent": "structure_control",
      "sub_intent": "softedge",
      "model_family": "sdxl",
      "requires_ref": true,
      "phase": 2,
      "description": "SDXL ControlNet SoftEdge — 부드러운 텍스처 유지하며 소재/색상만 교체. HED preprocessor. strength 0.65. BUG 벤치마크 반복 수정에 적합."
    }
  },

  "resolution_presets": {
    "1:1": [1024, 1024],
    "3:4": [896, 1152],
    "4:3": [1152, 896],
    "2:3": [832, 1216],
    "3:2": [1216, 832],
    "16:9": [1344, 768],
    "9:16": [768, 1344]
  },

  "channel_to_ratio": {
    "musinsa_hero": "3:4",
    "musinsa_detail": "3:4",
    "shop_pdp": "3:4",
    "shop_hero_banner": "16:9",
    "shop_category": "3:1-custom",
    "instagram_feed": "1:1",
    "instagram_portrait": "3:4",
    "instagram_story": "9:16",
    "lookbook_full": "2:3",
    "lookbook_half": "1:1",
    "lookbook_detail": "1:1"
  },

  "resolver_rules": {
    "priority_order": [
      "explicit_cli_resolution",
      "entry_meta_resolution",
      "channel_derived_resolution",
      "profile_default_resolution"
    ],
    "model_family_default": "sdxl",
    "fallback_workflow": "lookbook/sdxl_street_hires.json"
  }
}
